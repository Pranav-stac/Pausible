rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    /** Admin is defined only by `users/{uid}.role == "admin"` — set via Console or privileged backend. */
    function callerIsFirestoreAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /assessments/{assessmentId} {
      allow read: if true;
      allow write: if callerIsFirestoreAdmin();
    }

    match /attempts/{attemptId} {
      allow read: if callerIsFirestoreAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && (!request.resource.data.keys().hasAny(['claimSecret'])
          || (request.resource.data.claimSecret is string && request.resource.data.claimSecret.size() <= 256));
      allow update, delete: if callerIsFirestoreAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /share_snapshots/{token} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if callerIsFirestoreAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || callerIsFirestoreAdmin();
      allow create: if signedIn()
        && isOwner(uid)
        && !request.resource.data.keys().hasAny(['role']);
      allow update: if callerIsFirestoreAdmin()
        || (isOwner(uid)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isOwner(uid) || callerIsFirestoreAdmin();
    }

    /** Public read so clients respect free-results mode; admins or server SDK change values */
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if callerIsFirestoreAdmin();
    }

    match /discount_campaigns/{code} {
      allow read: if signedIn();
      allow write: if callerIsFirestoreAdmin();
    }

    match /payments/{id} {
      allow read: if callerIsFirestoreAdmin();
      allow write: if callerIsFirestoreAdmin();
    }
  }
}
