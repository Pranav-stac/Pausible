{
  "name": "pausible",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate:recommendation-seed": "node scripts/generate-recommendation-seed.mjs",
    "import:pda-v1": "node scripts/import-pda-v1.mjs",
    "import:revised-ocean": "node scripts/import-revised-ocean.mjs",
    "import:client-v7": "node scripts/import-client-v7.mjs",
    "seed:all": "npm run import:pda-v1 && npm run seed:firestore",
    "seed:firestore": "tsx --env-file=.env scripts/seed-firestore.ts",
    "wipe:firestore": "tsx --env-file=.env scripts/wipe-firestore.ts",
    "reset:firestore": "npm run wipe:firestore && npm run seed:all"
  },
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "exceljs": "^4.4.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "next": "16.2.6",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
